VITE_MAPTILER_KEY=your_maptiler_key_here
# Custom MapTiler map ID (UUID from your MapTiler Cloud account)
VITE_MAPTILER_MAP_ID=019d98dc-0865-7ac5-a184-a072f37b9509

# Base URL of the deployed Express API (Railway URL in production, empty for dev proxy)
# Example: https://terranthro-api.up.railway.app
VITE_API_BASE_URL=

# Shared API key matching INTERNAL_API_KEY on the server
VITE_INTERNAL_API_KEY=
