# Server port (defaults to 8000 in app.js)
PORT=8000

# PostgreSQL connection string — supports Supabase, Neon, Railway, or local Docker
# Supabase (direct, not pooler):  postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Neon:                           postgresql://user:pass@ep-xyz.us-east-1.aws.neon.tech/neondb?sslmode=require
# Local Docker:                   postgresql://terranthro_user:terranthro_pass@localhost:5432/terranthro
DATABASE_URL=postgresql://terranthro_user:terranthro_pass@localhost:5432/terranthro

# Shared secret to protect /api/wineries and /api/vineyards endpoints
# Generate with: openssl rand -hex 32
# Leave empty to disable auth (dev only)
INTERNAL_API_KEY=

# Additional CORS origins beyond the defaults (comma-separated, no spaces)
# Example: https://wv.terranthro.com,https://app.terranthro.com
CORS_ORIGINS=

# Object storage (Cloudflare R2 / S3) for COG raster files
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=terranthro-data
AWS_REGION=us-west-2

# Redis (optional — for caching)
REDIS_URL=redis://localhost:6379

NODE_ENV=development
